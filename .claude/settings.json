{
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(uv run ruff*)",
      "Bash(uv run --dev ruff*)",
      "Bash(uv run pytest*)",
      "Bash(railway *)",
      "Bash(gh auth switch --user sova-claw)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git status --short)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "uv run --dev ruff check . && uv run --dev ruff format --check . && (cd agents/finance && uv run ruff check finance_api/ && uv run ruff format --check finance_api/)",
            "statusMessage": "Ruff check…"
          }
        ]
      }
    ]
  }
}
